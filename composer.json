{
    "name": "oi-lab/oi-laravel-notes",
    "description": "Polymorphic notes with attachments for Laravel applications",
    "type": "library",
    "keywords": [
        "laravel",
        "notes",
        "comments",
        "annotations",
        "attachments",
        "polymorphic"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "OI Lab",
            "email": "olivier@olacombe.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "oi-lab/oi-laravel-attachments": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "OiLab\\OiLaravelNotes\\": "src/",
            "OiLab\\OiLaravelNotes\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OiLab\\OiLaravelNotes\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OiLab\\OiLaravelNotes\\OiLaravelNotesServiceProvider"
            ]
        },
        "oi-lab": {
            "skills": [
                {
                    "name": "oilab-laravel-notes",
                    "description": "Polymorphic notes for Eloquent models",
                    "path": "resources/stubs/ai-skill.md",
                    "rules": "resources/stubs/claude-rules.md",
                    "section": "oi-lab/oi-laravel-notes rules"
                }
            ]
        }
    },
    "scripts": {
        "sync-ai-skills": [
            "@php scripts/sync-ai-skills.php"
        ],
        "post-autoload-dump": [
            "@php scripts/sync-ai-skills.php"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "../oi-laravel-attachments",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
